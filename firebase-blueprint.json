{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A hackathon project submitted by a user",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the project" },
        "url": { "type": "string", "description": "The URL of the project" },
        "description": { "type": "string", "description": "A short description of the project" },
        "createdBy": { "type": "string", "description": "The UID of the user who submitted the project" },
        "creatorName": { "type": "string", "description": "The display name of the user" },
        "createdAt": { "type": "string", "format": "date-time" },
        "thumbnail": { "type": "string", "description": "Thumbnail image URL (optional)" }
      },
      "required": ["title", "url", "createdBy", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all hackathon projects"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
