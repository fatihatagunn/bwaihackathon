rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.url is string && data.url.size() > 0 && data.url.size() <= 500 &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.createdBy) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'url', 'description']);
      allow delete: if isSignedIn() && isOwner(resource.data.createdBy);
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
